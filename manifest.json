{
  "manifest_version": 3,
  "name": "Pinterest Pin Grabber",
  "version": "1.0",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "cookies"
  ],
  "host_permissions": [
    "https://www.pinterest.com/*",
    "https://i.pinimg.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.pinterest.com/*"],
      "js": ["content.js"]
    }
  ]
}